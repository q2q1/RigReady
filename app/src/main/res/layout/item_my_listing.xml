<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardListing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardUseCompatPadding="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <ImageView
                android:id="@+id/ivListingImage"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="#EEEEEE"
                android:scaleType="centerCrop"
                android:contentDescription="listing image"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvListingName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ivListingImage"
                app:layout_constraintEnd_toStartOf="@id/btnUnlist"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginStart="10dp"/>

            <TextView
                android:id="@+id/tvListingPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="$0.00"
                app:layout_constraintStart_toEndOf="@id/ivListingImage"
                app:layout_constraintEnd_toStartOf="@id/btnUnlist"
                app:layout_constraintTop_toBottomOf="@id/tvListingName"
                android:layout_marginStart="10dp"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvListingStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="available"
                app:layout_constraintStart_toStartOf="@id/tvListingName"
                app:layout_constraintEnd_toStartOf="@id/btnUnlist"
                app:layout_constraintTop_toBottomOf="@id/tvListingPrice"
                android:layout_marginTop="6dp"/>

            <Button
                android:id="@+id/btnUnlist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unlist"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>

